<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <include
            layout="@layout/toolbar_fitbody"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tính chỉ số cơ thể của bạn"
                android:textColor="#AAAAAA"
                android:textSize="16sp"/>

            <EditText
                android:id="@+id/edtHeight"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Nhập chiều cao (cm)"
                android:inputType="numberDecimal"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:backgroundTint="#FFFFFF"
                android:layout_marginTop="32dp"/>

            <EditText
                android:id="@+id/edtWeight"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Nhập cân nặng (kg)"
                android:inputType="numberDecimal"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:backgroundTint="#FFFFFF"
                android:layout_marginTop="16dp"/>

            <Button
                android:id="@+id/btnCalculateBMI"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="TÍNH BMI"
                android:textStyle="bold"
                android:layout_marginTop="28dp"/>

            <TextView
                android:id="@+id/txtBMIResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kết quả BMI sẽ hiển thị tại đây"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="32dp"/>

            <TextView
                android:id="@+id/txtBMIStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#AAAAAA"
                android:textSize="18sp"
                android:gravity="center"
                android:layout_marginTop="12dp"/>

            <!-- Nutrition Recommendations -->
            <LinearLayout
                android:id="@+id/layoutNutrition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="32dp"
                android:padding="20dp"
                android:background="@drawable/bg_card_home"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 PHÂN TÍCH CHUYÊN SÂU"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <!-- Water Intake -->
                <TextView
                    android:id="@+id/txtWaterIntake"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💧 Lượng nước: 2.5 Lít/ngày"
                    android:textColor="#42A5F5"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <!-- Ideal Weight -->
                <TextView
                    android:id="@+id/txtIdealWeight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚖️ Cân nặng lý tưởng: 60 - 72 kg"
                    android:textColor="#FFCA28"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#33FFFFFF"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🥗 CHẾ ĐỘ DINH DƯỠNG"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/txtNutritionAdvice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#CCCCCC"
                    android:textSize="14sp"
                    android:lineSpacingExtra="6dp"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>